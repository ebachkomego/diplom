{
  "name": "taim-server",
  "version": "1.0.0",
  "description": "Сервер ИС планирования производственных заказов ОАО ТАиМ",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "migrate": "npx knex migrate:latest --knexfile knexfile.js",
    "seed": "npx knex seed:run --knexfile knexfile.js",
    "setup": "npm run migrate && npm run seed"
  },
  "dependencies": {
    "express": "^4.21.0",
    "sqlite3": "^5.1.7",
    "knex": "^3.1.0",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "joi": "^17.13.0",
    "cors": "^2.8.5",
    "morgan": "^1.10.0",
    "pg": "^8.11.3",
    "dotenv": "^16.4.5"
  }
}
